                    <a class="list-group-item list-group-item-action text-danger @(currentPage == "Logout" ? "active" : "")" asp-page="/Logout">🚪 Logout</a>
                </div>
            </nav>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 pt-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="border-top footer text-muted mt-4 py-2 bg-light">
        <div class="container text-center">
            &copy; 2025 - Blog_System - <a asp-area="" asp-page="/Privacy">Privacy</a>
