                            <a class="nav-link" asp-area="" asp-page="/Index">🏠 Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Privacy">🔒 Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 d-md-block sidebar p-0">
                <div class="list-group list-group-flush shadow-sm">
                    <a class="list-group-item list-group-item-action @(currentPage == "Index" ? "active" : "")" asp-page="/Index">🏠 Dashboard</a>
                    <a class="list-group-item list-group-item-action @(currentPage.StartsWith("Posts/Index") ? "active" : "")" asp-page="/Posts/Index">📝 Posts</a>
                    <a class="list-group-item list-group-item-action @(currentPage == "Category/Index" ? "active" : "")" asp-page="/Category/Index">📂 Categories</a>
                    <a class="list-group-item list-group-item-action @(currentPage == "Comments/Index" ? "active" : "")" asp-page="/Comments/Index">💬 Comments</a>
