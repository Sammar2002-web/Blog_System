    @inject Microsoft.AspNetCore.Mvc.Rendering.IHtmlHelper Html
@{
    string currentPage = ViewContext.RouteData.Values["page"]?.ToString()?.TrimStart('/') ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blog_System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Blog_System.styles.css" asp-append-version="true" />
    <style>
        .sidebar {
            height: 100vh;
            position: sticky;
            top: 0;
            background-color: antiquewhite;
            padding-top: 1rem;
            border-right: 1px solid #dee2e6;
        }

            .sidebar .list-group-item {
                transition: background-color 0.2s ease, color 0.2s ease;
            }

                .sidebar .list-group-item.active {
                    background-color: #0d6efd;
                    color: white;
                    font-weight: 600;
                    border: none;
                    box-shadow: inset 4px 0 0 #0b5ed7;
                }

                .sidebar .list-group-item:hover {
                    background-color: #e2e6ea;
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">📰 Blog_System</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">
