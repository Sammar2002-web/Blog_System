@page
@model Blog_System.Pages.Posts.DeleteModel

@{
    ViewData["Title"] = "Delete Post";
}

<div class="container mt-4">
    <h1 class="text-danger">Delete Post</h1>
    <div class="alert alert-warning">
        <h3>Are you sure you want to delete this post?</h3>
        <p class="mb-0">This action cannot be undone and will delete all associated comments.</p>
    </div>

    <div class="card border-danger mb-4">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Post Details</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Post.Title)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Post.Title)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Post.Description)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Post.Description)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Post.Content)</dt>
                <dd class="col-sm-9">
                    <div class="content-preview" style="max-height: 100px; overflow: hidden;">
                        @Html.Raw(Model.Post.Content)
                    </div>
                </dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Post.Status)</dt>
                <dd class="col-sm-9">
                    @{
                        var statusClass = Model.Post.Status ? "bg-success" : "bg-secondary";
                        var statusText = Model.Post.Status ? "Published" : "Draft";
                    }
                    <span class="badge @statusClass">
                        @statusText
                    </span>
                </dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Post.CreatedAt)</dt>
                <dd class="col-sm-9">@Model.Post.CreatedAt.Value.ToString("MMMM dd, yyyy h:mm tt")</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Post.LastUpdatedAt)</dt>
                <dd class="col-sm-9">
                    @(Model.Post.LastUpdatedAt?.ToString("MMMM dd, yyyy h:mm tt") ?? "Never updated")
                </dd>

                <dt class="col-sm-3">Comments</dt>
                <dd class="col-sm-9">
                    @if (Model.Post.Comment != null && Model.Post.Comment.Any())
                    {
                        <div class="comment-list mb-3" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var comment in Model.Post.Comment)
                            {
                                <div class="comment-item mb-2 p-2 border rounded">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-bold">Comment #@comment.Id</span>
                                        <small class="text-muted">@comment.PostedAt.ToString("MMM dd, h:mm tt")</small>
                                    </div>
                                    <div class="comment-content mt-1 small">@comment.Content</div>
                                    <small class="text-muted">By @comment.Auther</small>
                                </div>
                            }
                        </div>
                        <p class="text-danger small">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            All @Model.Post.Comment.Count comments will be deleted
                        </p>
                    }
                    else
                    {
                        <span class="text-muted">No comments</span>
                    }
                </dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Post.Category)</dt>
                <dd class="col-sm-9">
                    @if (Model.Post.Category != null)
                    {
                        <span>@Model.Post.Category.Name</span>
                        <span class="badge bg-info ms-2">ID: @Model.Post.Category.Id</span>
                    }
                    else
                    {
                        <span class="text-muted">No category assigned</span>
                    }
                </dd>
            </dl>

            <div class="mt-4">
                <form method="post">
                    <input type="hidden" asp-for="Post.Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash-fill"></i> Confirm Delete
                    </button>
                    <a asp-page="./Index" class="btn btn-outline-secondary ms-2">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .comment-item {
            background-color: #f8f9fa;
            transition: background-color 0.2s;
        }

            .comment-item:hover {
                background-color: #e9ecef;
            }

        .content-preview {
            border-left: 3px solid #dee2e6;
            padding-left: 10px;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
}