@page
@model Blog_System.Pages.Posts.IndexModel

@{
    ViewData["Title"] = "Blog Posts";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Blog Posts</h1>
        <a class="btn btn-primary" asp-page="Create">+ Create New Post</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Post[0].Title)</th>
                    <th>@Html.DisplayNameFor(model => model.Post[0].Content)</th>
                    <th>@Html.DisplayNameFor(model => model.Post[0].Description)</th>
                    <th>@Html.DisplayNameFor(model => model.Post[0].Status)</th>
                    <th>@Html.DisplayNameFor(model => model.Post[0].CreatedAt)</th>
                    <th>@Html.DisplayNameFor(model => model.Post[0].LastUpdatedAt)</th>
                    <th>@Html.DisplayNameFor(model => model.Post[0].Comment)</th>
                    <th>@Html.DisplayNameFor(model => model.Post[0].Category)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Post)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Title)</td>
                        <td class="text-truncate" style="max-width: 150px;">
                            @Html.DisplayFor(modelItem => item.Content)
                        </td>
                        <td class="text-truncate" style="max-width: 150px;">
                            @Html.DisplayFor(modelItem => item.Description)
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.Status)</td>
                        <td>@item.CreatedAt?.ToString("yyyy-MM-dd")</td>
                        <td>@item.LastUpdatedAt?.ToString("yyyy-MM-dd")</td>
                        <td>@Html.DisplayFor(modelItem => item.Comment.Id)</td>
                        <td>@Html.DisplayFor(modelItem => item.Category.Id)</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@item.Id">Edit</a>
                                <a class="btn btn-sm btn-outline-info" asp-page="./Details" asp-route-id="@item.Id">Details</a>
                                <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
