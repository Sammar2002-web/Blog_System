@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome to Blog Central";
}


<a asp-page="\User"> User </a>
<a asp-page="\Admin"> Admin </a>
<a asp-page="\Visitor"> Visitor </a>
<br />
<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Welcome to Blog Central</h1>
        <p class="lead">Your destination for insightful posts, personal stories, and the latest updates.</p>
        <a class="btn btn-primary btn-lg mt-3" asp-page="/Posts/Index">Browse Blog Posts</a>
    </div>

    <div class="row text-center mb-5">
        <div class="col-md-4">
            <i class="bi bi-pencil-square display-4 text-primary"></i>
            <h4 class="mt-3">Create</h4>
            <p>Share your thoughts, stories, and expertise with the world.</p>
        </div>
        <div class="col-md-4">
            <i class="bi bi-search display-4 text-success"></i>
            <h4 class="mt-3">Discover</h4>
            <p>Explore posts from various authors and categories.</p>
        </div>
        <div class="col-md-4">
            <i class="bi bi-chat-left-text display-4 text-danger"></i>
            <h4 class="mt-3">Engage</h4>
            <p>Comment, like, and interact with other bloggers.</p>
        </div>
    </div>

    <div class="text-center">
        <h2 class="mb-4">Latest Posts</h2>
        <p class="text-muted">Coming soon...</p>
    </div>
</div>
